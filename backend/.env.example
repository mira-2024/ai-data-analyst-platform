# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Multi-Agent Data Analyst"
APP_VERSION="0.1.0"
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── API ────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://analyst:analyst@localhost:5432/analyst_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ── Storage ────────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=storage

# Uncomment for S3:
# STORAGE_BACKEND=s3
# STORAGE_S3_BUCKET=your-bucket-name
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=your-access-key
# STORAGE_S3_SECRET_KEY=your-secret-key

# Uncomment for MinIO:
# STORAGE_BACKEND=minio
# STORAGE_S3_ENDPOINT_URL=http://localhost:9000

# ── AI / LLM ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-6
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0

# ── Agent Execution ────────────────────────────────────────────────────────────
AGENT_MAX_RETRIES=2
AGENT_RETRY_DELAY_SECONDS=2.0
AGENT_EXECUTION_TIMEOUT_SECONDS=300

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text    # "json" for production

# ── Auth (future) ──────────────────────────────────────────────────────────────
AUTH_ENABLED=false
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
